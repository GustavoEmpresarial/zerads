# Porta interna do servidor (nao alterar se usar docker-compose padrao)
PORT=3000

# Porta exposta no host da VPS (ex: 80 ou 3000)
HOST_PORT=3000

# Senha que a ZerAds deve enviar no parametro ?pwd=
CALLBACK_PASSWORD=troque_por_senha_forte

# Seu ref ID na ZerAds
ZERADS_REF=10776

# IPs permitidos para o callback (deixe vazio para aceitar qualquer IP)
# IP do servidor ZerAds: 162.0.208.108
ALLOWED_IPS=162.0.208.108

# Caminho do arquivo de log dentro do container (nao alterar)
LOG_FILE=/app/storage/logs/callback.log
